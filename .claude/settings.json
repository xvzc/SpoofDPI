{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "go test ./... && test -z \"$(gofmt -l .)\" && golangci-lint run",
            "timeout": 180,
            "statusMessage": "Running Go tests, format check, and golangci-lint..."
          }
        ]
      }
    ]
  }
}
